# =============================================================================
# VIDEO AUTOMATION SYSTEM — Environment Variables
# =============================================================================
# Copia este archivo como .env y rellena todos los valores
# cp .env.example .env
# NUNCA commitees .env al repositorio
# =============================================================================

# -----------------------------------------------------------------------------
# APIs Principales
# -----------------------------------------------------------------------------

# Anthropic Claude — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxx

# Runway Gen-3 — https://app.runwayml.com/account/api-keys
RUNWAY_API_KEY=xxx

# ElevenLabs TTS — https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=xxx
# ID de la voz a usar (ej: "21m00Tcm4TlvDq8ikWAM" = Rachel)
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# Modelo de ElevenLabs (eleven_multilingual_v2 para español)
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# OpenAI Whisper — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxx

# -----------------------------------------------------------------------------
# Google OAuth2 — Drive
# Crear proyecto en: https://console.cloud.google.com/
# Habilitar: Google Drive API
# Ejecutar: node scripts/setup-google-auth.js para obtener REFRESH_TOKEN
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx
GOOGLE_REFRESH_TOKEN=xxx

# -----------------------------------------------------------------------------
# Google OAuth2 — YouTube (credenciales separadas)
# Habilitar: YouTube Data API v3
# -----------------------------------------------------------------------------
YOUTUBE_CLIENT_ID=xxx.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=xxx
YOUTUBE_REFRESH_TOKEN=xxx

# IDs de carpetas en Google Drive
# Crear 3 carpetas en Drive y copiar sus IDs de la URL
GDRIVE_PENDING_FOLDER_ID=xxx      # Carpeta "Videos Pendientes"
GDRIVE_APPROVED_FOLDER_ID=xxx     # Carpeta "Videos Aprobados"
GDRIVE_REJECTED_FOLDER_ID=xxx     # Carpeta "Videos Rechazados"

# -----------------------------------------------------------------------------
# Telegram Bot
# Crear bot con @BotFather en Telegram
# Obtener CHAT_ID: enviar mensaje al bot y visitar
# https://api.telegram.org/bot{TOKEN}/getUpdates
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=xxx
TELEGRAM_CHAT_ID=xxx              # Tu chat ID personal (ej: 123456789)

# -----------------------------------------------------------------------------
# n8n Configuration
# -----------------------------------------------------------------------------
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme_strong_password
N8N_ENCRYPTION_KEY=changeme_32char_random_string_here
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=http
# Cambiar por la IP o dominio de tu VPS cuando esté en producción
WEBHOOK_URL=https://noctisiops-n8n.gpsefe.easypanel.host/

# -----------------------------------------------------------------------------
# PostgreSQL (backend de n8n)
# -----------------------------------------------------------------------------
POSTGRES_DB=n8n
POSTGRES_USER=n8n_user
POSTGRES_PASSWORD=changeme_strong_db_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# File Watcher
# -----------------------------------------------------------------------------
# Ruta DENTRO del contenedor donde se monta la carpeta de ViralScout
VIRALSCOUT_WATCH_DIR=/watch
# Webhook de n8n que recibe los scripts parseados
N8N_WEBHOOK_URL=http://n8n:5678/webhook/new-script
# Intervalo de polling en ms (5000 = 5 segundos)
WATCH_POLL_INTERVAL=5000

# -----------------------------------------------------------------------------
# Remotion Renderer
# -----------------------------------------------------------------------------
REMOTION_PORT=3001
# Concurrencia de render (ajustar según CPU disponible)
REMOTION_CONCURRENCY=4
# Ruta donde se guardan los videos temporales (dentro del contenedor)
TEMP_VIDEOS_DIR=/tmp/videos

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
NODE_ENV=production
TZ=Europe/Dublin
